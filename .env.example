# SUPABASE CREDENTIALS (Find these in Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SECRET SERVICE ROLE KEY (Only for Serverless Functions, NOT exposed to Frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# VERCEL / SERVERLESS CONFIG
# ENVIRONMENT=development

# SECURITY CONFIG
# JWT_SECRET=your-very-strong-secret-key-for-session-tokens
